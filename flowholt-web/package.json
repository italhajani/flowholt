{
  "name": "flowholt-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:backend": "node tests/backend/run-backend-tests.mjs",
    "daemon": "node --env-file=.env.local scripts/flowholt-daemon.mjs --all",
    "daemon:worker": "node --env-file=.env.local scripts/flowholt-daemon.mjs --worker",
    "daemon:scheduler": "node --env-file=.env.local scripts/flowholt-daemon.mjs --scheduler",
    "migrations:status": "node scripts/flowholt-migrations.mjs --status",
    "migrations:apply": "node scripts/flowholt-migrations.mjs --apply",
    "backup:create": "node scripts/flowholt-backup.mjs create",
    "backup:restore": "node scripts/flowholt-backup.mjs restore"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@xyflow/react": "^12.10.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
