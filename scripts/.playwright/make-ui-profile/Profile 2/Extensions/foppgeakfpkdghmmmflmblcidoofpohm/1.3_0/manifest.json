{
   "action": {
      "default_icon": {
         "64": "icons/icon64.png",
         "96": "icons/icon96.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js"
   },
   "description": "Extract a website's HTML, CSS, JS, and images, then download everything as a ZIP file.",
   "host_permissions": [ "https://*/*", "http://*/*" ],
   "icons": {
      "64": "icons/icon64.png",
      "96": "icons/icon96.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Website Code Extractor",
   "permissions": [ "activeTab", "downloads", "scripting" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.3"
}
