## ──────────────────────────────────────────────
##  FlowHolt — Environment Configuration
## ──────────────────────────────────────────────
##  Copy this to  backend/.env  and fill in your values.
##  Lines starting with # are comments.  Empty values = disabled/mock.
## ──────────────────────────────────────────────

# ── General ──
APP_ENV=development
API_PREFIX=/api
CORS_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5173

# ── Database ──
# SQLite (default, zero cost — leave DATABASE_URL empty)
DATABASE_PATH=backend/flowholt.db

# Supabase (production — set both to enable)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_EXPECTED_AUDIENCE=authenticated
SUPABASE_JWKS_CACHE_TTL_SECONDS=600

# ── Authentication ──
SESSION_SECRET=change-this-before-going-online
SESSION_TTL_HOURS=168
ALLOW_DEV_LOGIN=true

# ── LLM Providers (auto-fallback chain: first key found wins) ──
# Set LLM_PROVIDER=auto for automatic fallback, or force one provider.
LLM_PROVIDER=auto

# Groq (FREE tier — https://console.groq.com — best free option)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (FREE tier — https://aistudio.google.com)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# xAI / Grok (FREE tier available — https://console.x.ai)
XAI_API_KEY=
XAI_MODEL=grok-3

# DeepSeek (very cheap — https://platform.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Ollama (local, free — https://ollama.com — run your own models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI (paid — https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (paid — https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Copilot / Chat AI Model ──
# Which LLM powers the in-platform Copilot chat and AI features.
# Uses the same provider chain above. Override here if you want Copilot
# on a different model than workflow node AI.
COPILOT_MODEL=
COPILOT_MAX_TOKENS=2048

# ── Free Tier / Token System ──
# Number of free AI tokens per user per month (0 = unlimited in dev)
FREE_TIER_MONTHLY_TOKENS=50000
# Number of free workflow executions per user per month
FREE_TIER_MONTHLY_EXECUTIONS=1000

# ── Email / Notifications ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@flowholt.local
SMTP_USE_TLS=true

# ── Integrations ──
SLACK_DEFAULT_WEBHOOK_URL=

# ── Webhooks & Execution ──
SCHEDULER_SECRET=
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
EXECUTION_MODE=sync
WORKER_LEASE_SECONDS=60

# Execution data retention
EXECUTION_ARTIFACT_RETENTION_DAYS=14
EXEC_MAX_COUNT=10000
EXEC_DELETE_BUFFER_HOURS=1
EXEC_ANALYTICS_RETAIN_DAYS=90

# ── Vault ──
VAULT_ENCRYPTION_KEY=